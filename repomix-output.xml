.section {
  position: relative;
  z-index: 1;
  padding: 6rem 0 0;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.container {
  max-width: 1160px;
  margin: 0 auto;
  padding: 0 2rem;
  width: 100%;
  flex: 1;
}

