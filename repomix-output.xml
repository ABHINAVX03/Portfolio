// pitch, not an engineering explanation.

import { BoundaryDecision } from "@/utils/caseStudies/types";

export default function BoundaryDecisionBlock({ decision }: { decision: BoundaryDecision }) {
  return (
    <div style={{
      padding: "22px 24px",
