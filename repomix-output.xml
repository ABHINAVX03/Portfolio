<file path="src/components/Navbar/Navbar.tsx">
"use client";

import { AnimatePresence, motion } from "framer-motion";
import Link from "next/link";
import { useEffect, useState } from "react";
import { FiMenu, FiMoon, FiSun, FiX } from "react-icons/fi";

const NAV_ITEMS = [
  { label: "Home", href: "#home" },
  { label: "Projects", href: "#projects" },
  { label: "About", href: "#about" },
  { label: "Contact", href: "#contact" },
];

const Navbar = () => {
  const [isScrolled, setIsScrolled] = useState(false);
  const [isMenuOpen, setIsMenuOpen] = useState(false);
  const [isDark, setIsDark] = useState(true);

  useEffect(() => {
    const onScroll = () => setIsScrolled(window.scrollY > 10);
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
    return () => window.removeEventListener("scroll", onScroll);
  }, []);

  useEffect(() => {
    const storedTheme = window.localStorage.getItem("theme");
    const shouldUseDark = storedTheme ? storedTheme === "dark" : true;
    setIsDark(shouldUseDark);
    document.documentElement.classList.toggle("dark", shouldUseDark);
  }, []);

  useEffect(() => {
    if (isMenuOpen) {
      document.body.style.overflow = "hidden";
    } else {
      document.body.style.overflow = "";
    }
    return () => {
      document.body.style.overflow = "";
    };
  }, [isMenuOpen]);

  const toggleTheme = () => {
    const next = !isDark;
    setIsDark(next);
    document.documentElement.classList.toggle("dark", next);
    window.localStorage.setItem("theme", next ? "dark" : "light");
  };

  return (
    <header className="sticky top-0 z-50 px-4 py-4 sm:px-6">
      <nav role="navigation"
        className={`mx-auto flex w-full max-w-7xl items-center justify-between rounded-2xl border px-4 py-3 transition-all duration-300 sm:px-6 ${
          isScrolled
            ? "border-black/10 bg-white/70 shadow-[0_10px_30px_rgba(0,0,0,0.06)] backdrop-blur-xl dark:border-white/15 dark:bg-[#05070f]/70"
            : "border-black/5 bg-white/35 backdrop-blur-lg dark:border-white/10 dark:bg-[#05070f]/45"
        }`}
        aria-label="Main navigation"
      >
        <Link
          href="#home"
          className="inline-flex items-center gap-3 rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#22c470]"
          aria-label="Go to home section"
        >
          <span className="grid h-10 w-10 place-items-center rounded-xl border border-black/15 bg-black/5 text-sm font-bold text-slate-800 dark:border-white/20 dark:bg-white/5 dark:text-white">
            AG
          </span>
          <div className="hidden sm:block">
            <p className="text-sm font-semibold text-slate-900 dark:text-white">Abhinav Gupta</p>
            <div className="flex items-center gap-2 text-xs text-slate-600 dark:text-white/70">
              <span className="relative inline-flex h-2 w-2">
                <span className="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#22c470] opacity-75" />
                <span className="relative inline-flex h-2 w-2 rounded-full bg-[#22c470]" />
              </span>
              Available for opportunities
            </div>
          </div>
        </Link>

        <ul className="hidden items-center gap-6 md:flex">
          {NAV_ITEMS.map((item) => (
            <li key={item.href}>
              <Link
                href={item.href}
                className="text-sm font-medium text-slate-700 transition hover:text-slate-950 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#4F8EF7] dark:text-white/80 dark:hover:text-white"
              >
                {item.label}
              </Link>
            </li>
          ))}
        </ul>

        <div className="flex items-center gap-2">
          {/* Theme Toggle Button */}
          <button
            type="button"
            onClick={toggleTheme}
            className="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-black/10 bg-black/5 text-slate-800 transition hover:bg-black/10 hover:text-[#22c470] dark:border-white/15 dark:bg-white/5 dark:text-white dark:hover:bg-white/10 dark:hover:text-[#22c470] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#22c470]"
            aria-label="Toggle theme"
          >
            {isDark ? <FiSun size={18} /> : <FiMoon size={18} />}
          </button>

          <a
            href="/resume/Resume.pdf"
            download
            className="hidden rounded-xl bg-[#22c470] px-4 py-2.5 text-sm font-semibold text-black transition hover:bg-[#32d983] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#22c470] md:inline-block"
            aria-label="Download resume"
          >
            Resume
          </a>

          <button
            type="button"
            onClick={() => setIsMenuOpen((prev) => !prev)}
            className="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-black/10 bg-black/5 text-slate-800 md:hidden dark:border-white/15 dark:bg-white/5 dark:text-white" aria-controls="mobile-menu"
            aria-label={isMenuOpen ? "Close menu" : "Open menu"}
            aria-expanded={isMenuOpen}
          >
            {isMenuOpen ? <FiX size={18} /> : <FiMenu size={18} />}
          </button>
        </div>
      </nav>

      <AnimatePresence>
        {isMenuOpen && (
          <motion.div id="mobile-menu" initial={{ opacity: 0, y: -12 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -12 }}
            transition={{ duration: 0.2 }}
            className="mx-auto mt-2 w-full max-w-7xl rounded-2xl border border-black/10 bg-white/95 p-4 backdrop-blur-xl dark:border-white/15 dark:bg-[#05070f]/95 md:hidden"
          >
            <ul className="space-y-2">
              {NAV_ITEMS.map((item) => (
                <li key={item.href}>
                  <Link
                    href={item.href}
                    onClick={() => setIsMenuOpen(false)}
                    className="block rounded-lg px-3 py-2 text-sm text-slate-800 transition hover:bg-slate-100 hover:text-slate-950 dark:text-white/85 dark:hover:bg-white/10 dark:hover:text-white"
                  >
                    {item.label}
                  </Link>
                </li>
              ))}
            </ul>
            <a
              href="/resume/Resume.pdf"
              download
              className="mt-3 block rounded-lg bg-[#22c470] px-4 py-2 text-center text-sm font-semibold text-black hover:bg-[#32d983]"
              aria-label="Download resume from mobile menu"
            >
              Download Resume
            </a>
          </motion.div>
        )}
      </AnimatePresence>
    </header>
  );
};

export default Navbar;
</file>

<file path="src/components/Projects/projects.module.css">
/* ============================================
   UNIQUE PROJECTS SECTION — Masonry Grid
   ============================================ */

.section {
  position: relative;
  z-index: 1;
  padding: 7rem 0;
  min-height: 100vh;
  overflow: hidden;
}

.section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(circle at 30% 70%, rgba(79, 142, 247, 0.06) 0%, transparent 50%),
    radial-gradient(circle at 70% 30%, rgba(0, 212, 255, 0.06) 0%, transparent 50%);
  animation: projectGlow 12s ease-in-out infinite;
  pointer-events: none;
}

@keyframes projectGlow {
  0%, 100% {
    background:
      radial-gradient(circle at 30% 70%, rgba(79, 142, 247, 0.06) 0%, transparent 50%),
      radial-gradient(circle at 70% 30%, rgba(0, 212, 255, 0.06) 0%, transparent 50%);
  }
  50% {
    background:
      radial-gradient(circle at 40% 60%, rgba(79, 142, 247, 0.09) 0%, transparent 50%),
      radial-gradient(circle at 60% 40%, rgba(0, 212, 255, 0.09) 0%, transparent 50%);
  }
}

.container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 2rem;
  width: 100%;
}

/* ---- Header ---- */
.header {
  text-align: center;
  margin-bottom: 5rem;
}

.labelRow {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  margin-bottom: 1.5rem;
}

.labelLine {
  width: 56px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--c-primary));
  display: block;
}

.labelLine:last-child {
  background: linear-gradient(90deg, var(--c-primary), transparent);
}

.labelText {
  font-family: var(--font-mono);
  font-size: 11.5px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--c-primary);
}

.heading {
  font-family: var(--font-sans);
  font-size: clamp(40px, 5.5vw, 64px);
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1.05;
  color: var(--c-text-primary);
  margin-bottom: 1rem;
}

.headingAccent {
  background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-cyan) 60%);
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
}

.subheading {
  font-family: var(--font-body);
  font-size: 17px;
  color: var(--c-text-secondary);
  max-width: 580px;
  margin: 0 auto 2.5rem;
  line-height: 1.7;
}

/* Stat pills */
.statRow {
  display: inline-flex;
  align-items: center;
  gap: 0;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--c-border);
  border-radius: var(--radius-full);
  padding: 12px 28px;
  gap: 24px;
}

.statPill {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
}

.statNum {
  font-family: var(--font-sans);
  font-size: 16px;
  font-weight: 800;
  letter-spacing: -0.02em;
  background: linear-gradient(135deg, var(--c-primary), var(--c-cyan));
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
}

.statLabel {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--c-text-muted);
}

.statDivider {
  width: 1px;
  height: 32px;
  background: var(--c-border);
}

/* ============================================
   FLAGSHIP CASE STUDY
   ============================================ */
.flagship {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(360px, 0.9fr);
  gap: 2rem;
  align-items: stretch;
  margin-bottom: 4rem;
  padding: 1.25rem;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24px;
  background: linear-gradient(135deg, rgba(8, 12, 22, 0.96), rgba(14, 24, 36, 0.82));
  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
  overflow: hidden;
}

.flagshipContent {
  padding: 1.25rem;
}

.flagshipEyebrow {
  display: inline-flex;
  margin-bottom: 1rem;
  padding: 6px 10px;
  border: 1px solid rgba(16, 185, 129, 0.3);
  border-radius: 999px;
  background: rgba(16, 185, 129, 0.1);
  color: #74f2b2;
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.flagshipTitle {
  margin: 0 0 0.9rem;
  color: #fff;
  font-family: var(--font-sans);
  font-size: clamp(28px, 3.2vw, 44px);
  font-weight: 900;
  letter-spacing: -0.03em;
  line-height: 1.05;
}

.flagshipSummary {
  max-width: 680px;
  margin: 0 0 1.5rem;
  color: rgba(255, 255, 255, 0.72);
  font-size: 15px;
  line-height: 1.7;
}

.caseGrid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.9rem;
}

.casePanel {
  min-height: 132px;
  padding: 1rem;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.035);
}

.casePanel span {
  display: block;
  margin-bottom: 0.6rem;
  color: #4f8ef7;
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.casePanel p,
.casePanel li {
  margin: 0;
  color: rgba(255, 255, 255, 0.72);
  font-size: 13px;
  line-height: 1.55;
}

.casePanel ul {
  margin: 0;
  padding-left: 1rem;
}

.apiList {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.apiList small {
  padding: 6px 8px;
  border: 1px solid rgba(0, 212, 255, 0.22);
  border-radius: 8px;
  background: rgba(0, 212, 255, 0.08);
  color: #b7efff;
  font-family: var(--font-mono);
  font-size: 10px;
}

.flagshipActions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
  margin-top: 1.4rem;
}

.flagshipActions a {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 42px;
  padding: 0 14px;
  border: 1px solid rgba(255, 255, 255, 0.14);
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.06);
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  transition: all 0.2s ease;
}

.flagshipActions a:hover {
  border-color: rgba(79, 142, 247, 0.45);
  background: rgba(79, 142, 247, 0.16);
  transform: translateY(-2px);
}

.flagshipVisual {
  position: relative;
  min-height: 100%;
  border-radius: 18px;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.28);
}

.flagshipImage {
  width: 100%;
  height: 100%;
  min-height: 420px;
  object-fit: cover;
  display: block;
}

.proofStrip {
  position: absolute;
  left: 16px;
  right: 16px;
  bottom: 16px;
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.proofStrip span {
  padding: 7px 10px;
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.72);
  color: #fff;
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

/* ============================================
   UNIQUE MASONRY GRID
   ============================================ */
.masonryGrid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
  gap: 2rem;
  margin-top: 2rem;
}

/* ============================================
   UNIQUE PROJECT CARD
   ============================================ */
.projectCard {
  position: relative;
  background: rgba(11, 15, 26, 0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 20px;
  overflow: hidden;
  cursor: pointer;
  transition: all 0.4s ease;
}

.projectCard:hover {
  border-color: rgba(255, 255, 255, 0.15);
  box-shadow: 0 25px 60px rgba(0,0,0,0.4), 0 0 40px var(--glow);
}

/* Card Image */
.cardImage {
  position: relative;
  width: 100%;
  height: 220px;
  overflow: hidden;
}

.image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.projectCard:hover .image {
  transform: scale(1.05);
}

.imageOverlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.3) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.projectCard:hover .imageOverlay {
  opacity: 1;
}

/* Project Number */
.projectNumber {
  position: absolute;
  top: 16px;
  right: 16px;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  color: white;
  font-family: var(--font-mono);
  font-size: 12px;
  font-weight: 700;
  padding: 6px 12px;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  z-index: 2;
}

.web3Badge {
  position: absolute;
  top: 16px;
  left: 16px;
  z-index: 2;
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #a8f0ff;
  padding: 6px 10px;
  border-radius: 999px;
  border: 1px solid rgba(0, 212, 255, 0.45);
  background: rgba(0, 212, 255, 0.14);
  backdrop-filter: blur(8px);
}

/* Hover Content */
.hoverContent {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
}

.hoverActions {
  display: flex;
  gap: 1rem;
}

.actionBtn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 20px;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 12px;
  color: white;
  text-decoration: none;
  font-family: var(--font-sans);
  font-size: 14px;
  font-weight: 600;
  transition: all 0.3s ease;
}

.actionBtn:hover {
  background: rgba(255, 255, 255, 0.25);
  border-color: rgba(255, 255, 255, 0.4);
  transform: translateY(-2px);
}

/* Card Content */
.cardContent {
  padding: 1.5rem;
}

.cardHeader {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 0.75rem;
}

.projectTitle {
  font-family: var(--font-sans);
  font-size: 20px;
  font-weight: 700;
  color: var(--c-text-primary);
  margin: 0;
  line-height: 1.3;
}

.projectType {
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 4px 10px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 8px;
  white-space: nowrap;
}

.projectDesc {
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--c-text-secondary);
  line-height: 1.6;
  margin: 0 0 1rem 0;
}

/* Tech Stack */
.techStack {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.techTag {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.02em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 8px;
  border: 1px solid transparent;
  color: var(--c-text-primary);
  transition: all 0.3s ease;
}

/* Animated Border */
.cardBorder {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2px;
  transform-origin: left;
}

/* Responsive */
@media (max-width: 1024px) {
  .flagship {
    grid-template-columns: 1fr;
  }

  .flagshipImage {
    min-height: 320px;
  }

  .masonryGrid {
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
}

@media (max-width: 768px) {
  .section {
    padding: 4rem 0;
  }

  .container {
    padding: 0 1rem;
  }

  .header {
    margin-bottom: 3rem;
  }

  .flagship {
    gap: 1rem;
    margin-bottom: 3rem;
    padding: 0.9rem;
    border-radius: 18px;
  }

  .flagshipContent {
    padding: 0.5rem;
  }

  .caseGrid {
    grid-template-columns: 1fr;
  }

  .casePanel {
    min-height: auto;
  }

  .flagshipImage {
    min-height: 240px;
  }

  .flagshipActions a {
    flex: 1 1 140px;
    justify-content: center;
  }

  .masonryGrid {
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .heading {
    font-size: clamp(32px, 6vw, 48px);
  }

  .statRow {
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
    padding: 16px 20px;
    border-radius: 18px;
  }

  .statDivider {
    display: none;
  }

  .cardImage {
    height: 190px;
  }

  .cardContent {
    padding: 1.15rem;
  }

  .cardHeader {
    flex-direction: column;
    gap: 0.55rem;
  }

  .projectType {
    align-self: flex-start;
    white-space: normal;
  }

  .hoverContent {
    top: auto;
    bottom: 12px;
    justify-content: flex-start;
    padding: 0 12px;
    pointer-events: none;
  }

  .hoverActions {
    gap: 0.5rem;
  }

  .actionBtn {
    padding: 9px 12px;
    font-size: 12px;
    pointer-events: auto;
    background: rgba(6, 8, 17, 0.82);
  }
}

@media (hover: none) and (pointer: coarse) {
  .hoverContent {
    opacity: 1;
  }
}
</file>

