  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--c-emerald);
  box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.3);
  animation: pulse 2.4s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.3); }
  50%       { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
}

/* Heading */
.headingBlock {
