  border-color: rgba(79, 142, 247, 0.3);
  background: rgba(79, 142, 247, 0.08);
}

.badge_cyan {
  color: var(--c-cyan);
  border-color: rgba(0, 212, 255, 0.3);
  background: rgba(0, 212, 255, 0.08);
}

.badge_violet {
  color: var(--c-violet);
  border-color: rgba(139, 92, 246, 0.3);
  background: rgba(139, 92, 246, 0.08);
}

.badge_emerald {
  color: var(--c-emerald);
  border-color: rgba(16, 185, 129, 0.3);
  background: rgba(16, 185, 129, 0.08);
}

/* Action buttons */
.actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 4px;
}

.btnPrimary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  font-family: var(--font-sans);
  font-size: 14px;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, var(--c-primary), var(--c-cyan));
  border-radius: var(--radius-full);
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: var(--transition-base);
  box-shadow: 0 4px 20px rgba(79, 142, 247, 0.3);
  letter-spacing: 0.01em;
}

.btnPrimary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(79, 142, 247, 0.5);
}

.btnOutline {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  font-family: var(--font-sans);
  font-size: 14px;
  font-weight: 600;
  color: var(--c-text-primary);
  background: transparent;
  border-radius: var(--radius-full);
  border: 1px solid rgba(255, 255, 255, 0.12);
  cursor: pointer;
  text-decoration: none;
  transition: var(--transition-base);
}

.btnOutline:hover {
  border-color: rgba(79, 142, 247, 0.4);
  background: rgba(79, 142, 247, 0.08);
  transform: translateY(-2px);
}

/* Social links */
.socials {
  display: flex;
  gap: 12px;
  margin-top: 24px;
}

.socialLink {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: var(--radius-md);
  border: 1px solid var(--c-border);
  color: var(--c-text-secondary);
  background: rgba(255, 255, 255, 0.03);
  transition: var(--transition-base);
  cursor: pointer;
}

.socialLink:hover {
  color: var(--c-primary);
  border-color: rgba(79, 142, 247, 0.4);
  background: rgba(79, 142, 247, 0.08);
  transform: translateY(-2px);
  box-shadow: 0 4px 15px rgba(79, 142, 247, 0.2);
}

/* ---- Right: Code card ---- */
.codeCard {
  background: rgba(10, 13, 23, 0.9);
  border: 1px solid rgba(79, 142, 247, 0.15);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(79, 142, 247, 0.05), inset 0 1px 0 rgba(255,255,255,0.04);
  animation: floatY 5s ease-in-out infinite;
}

.codeHeader {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 12px 16px;
  background: rgba(255, 255, 255, 0.03);
  border-bottom: 1px solid rgba(79, 142, 247, 0.1);
}

.codeDot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
}

.codeFileName {
  margin-left: 8px;
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--c-text-muted);
  letter-spacing: 0.04em;
}

.codeBody {
  padding: 20px 24px;
  overflow: hidden;
}

.codeBody code {
  font-family: var(--font-mono);
  font-size: 13px;
  line-height: 1.85;
  color: #e2e8f0;
  white-space: pre;
  display: block;
}

/* Syntax color hints */
.codeBody code {
  color: #94a3b8;
}

/* Scroll indicator */
.scrollIndicator {
  position: absolute;
  bottom: 32px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  color: var(--c-text-muted);
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.scrollLine {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, var(--c-primary), transparent);
  animation: scrollLineAnim 1.8s ease-in-out infinite;
}

@keyframes scrollLineAnim {
  0%   { opacity: 0; transform: scaleY(0); transform-origin: top; }
  50%  { opacity: 1; transform: scaleY(1); }
  100% { opacity: 0; transform: scaleY(0); transform-origin: bottom; }
}

@keyframes floatY {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-14px); }
}

/* ---- Responsive ---- */
@media (max-width: 900px) {
  .container {
    grid-template-columns: 1fr;
    text-align: center;
    gap: 3rem;
    padding-top: 40px;
  }

  .content {
    align-items: center;
  }

  .description {
    text-align: center;
  }

  .badges {
    justify-content: center;
  }

  .actions {
    justify-content: center;
  }

  .socials {
    justify-content: center;
  }

  .codeCard {
    max-width: 420px;
    margin: 0 auto;
    animation: none;
  }

  .scrollIndicator {
    display: none;
  }
}

@media (max-width: 480px) {
  .hero {
    padding-top: 90px;
  }

  .name {
    font-size: 48px;
  }

  .codeBody code {
    font-size: 11px;
  }
}
</file>

