  -webkit-backdrop-filter: blur(16px);
  position: relative;
  overflow: hidden;
}

.formColumn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--c-primary), var(--c-cyan), transparent);
